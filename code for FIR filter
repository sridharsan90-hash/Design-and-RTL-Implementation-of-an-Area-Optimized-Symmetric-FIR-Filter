###################### TESTBENCH CODE FOR FIR FILTER #####################
module tb_advanced_fir;
    reg clk, rst_n, load_en;
    reg [3:0] addr;
    reg signed [15:0] c_in, x_in;
    wire signed [15:0] y_out;

    // Explicit Port Mapping (Fixes the .* error)
    advanced_fir uut (
        .clk(clk),
        .rst_n(rst_n),
        .load_en(load_en),
        .addr(addr),
        .c_in(c_in),
        .x_in(x_in),
        .y_out(y_out)
    );

    // Clock Generation
    always #5 clk = ~clk;

    initial begin
        // Setup for Waveforms
        $dumpfile("dump.vcd"); 
        $dumpvars(0, tb_advanced_fir);

        // Initialize
        clk = 0; rst_n = 0; load_en = 0; x_in = 0; addr = 0; c_in = 0;
        #20 rst_n = 1;

        // --- STEP 1: LOAD COEFFICIENTS ---
        load_coeff(4'd0, 16'd143);
        load_coeff(4'd1, 16'd786);
        load_coeff(4'd2, 16'd2687);
        load_coeff(4'd3, 16'd4576);

        // --- STEP 2: APPLY SIGNAL ---
        #20 x_in = 16'd8000; // Apply a step input
        #200;
        x_in = -16'd4000;    // Change signal
        #200;

        $display("Simulation Finished");
        $finish;
    end

    // Task to load coefficients
    task load_coeff;
        input [3:0] a;
        input [15:0] d;
        begin
            @(posedge clk);
            load_en = 1; 
            addr = a; 
            c_in = d;
           @(posedge clk);
            load_en = 0;
        end
    endtask
############################ DESIGN CODE ##################
module advanced_fir (
    input clk,
    input rst_n,
    input load_en,
    input [3:0] addr,
    input signed [15:0] c_in, 
    input signed [15:0] x_in,
    output reg signed [15:0] y_out
);

    // Symmetric Coefficients (Only 4 needed for 8 taps)
    reg signed [15:0] h [0:3];
    // Accumulator registers for Transposed Form
    reg signed [31:0] acc [0:7];
    integer i;

    // 1. Coefficient Loading Logic
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            for (i=0; i<4; i=i+1) h[i] <= 16'd0;
        end else if (load_en) begin
            h[addr] <= c_in;
        end
    end

    // 2. Symmetric Transposed Logic (Expanded for Compatibility)
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            for (i=0; i<8; i=i+1) acc[i] <= 32'd0;
        end else begin
            // Stage 0-3 (First half)
            acc[0] <= (x_in * h[0]);
            acc[1] <= acc[0] + (x_in * h[1]);
            acc[2] <= acc[1] + (x_in * h[2]);
            acc[3] <= acc[2] + (x_in * h[3]);
            // Stage 4-7 (Symmetric second half - reusing h in reverse)
            acc[4] <= acc[3] + (x_in * h[3]);
            acc[5] <= acc[4] + (x_in * h[2]);
            acc[6] <= acc[5] + (x_in * h[1]);
            acc[7] <= acc[6] + (x_in * h[0]);
        end
    end

    // 3. Output with Scaling
    always @(posedge clk) begin
        y_out <= acc[7][29:14];
    end

endmodule


endmodule
